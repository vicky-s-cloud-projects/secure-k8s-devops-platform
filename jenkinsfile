pipeline {

    agent any

    environment {
        AWS_REGION = "eu-west-2"
        ECR_REPO = "998948477550.dkr.ecr.eu-west-2.amazonaws.com/boutique-frontend"
        IMAGE_TAG = "v${BUILD_NUMBER}"
    }

    stages {

        stage('Clone') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/vicky-s-cloud-projects/secure-k8s-devops-platform.git',
                    credentialsId: 'github-cred'
            }
        }

        stage('Build') {
            steps {
                sh """
                docker build -t boutique-frontend ./apps/online-boutique/src/frontend
                docker tag boutique-frontend $ECR_REPO:$IMAGE_TAG
                """
            }
        }

        stage('Login ECR') {
            steps {
                sh """
                aws ecr get-login-password --region $AWS_REGION |
                docker login --username AWS --password-stdin 998948477550.dkr.ecr.eu-west-2.amazonaws.com
                """
            }
        }

        stage('Push') {
            steps {
                sh """
                docker push $ECR_REPO:$IMAGE_TAG
                """
            }
        }

        stage('Deploy') {
            steps {
                sh """
                kubectl set image deployment/frontend frontend=$ECR_REPO:$IMAGE_TAG -n boutique
                """
            }
        }

    }
}